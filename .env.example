# ─────────────────────────────────────────────
# Supabase（資料庫）
# ─────────────────────────────────────────────
SUPABASE_URL=
# Service role 金鑰，僅限伺服器端使用，切勿暴露給瀏覽器
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# LINE Messaging API
# ─────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ─────────────────────────────────────────────
# Upstash QStash（排程 / 非同步任務）
# ─────────────────────────────────────────────
# 發布任務用 token，僅限伺服器端
QSTASH_TOKEN=""
# webhook 簽章驗證（金鑰輪替用）
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ─────────────────────────────────────────────
# 應用程式網址
# ─────────────────────────────────────────────
# 對外公開網址，供 OAuth 回調與 QStash 回呼使用（例：https://meet-baby.vercel.app）
APP_BASE_URL=

# LIFF App ID，會帶到前端（NEXT_PUBLIC_ 前綴）
NEXT_PUBLIC_LIFF_ID=

# ─────────────────────────────────────────────
# Google 整合
# ─────────────────────────────────────────────
# Service Account 憑證 JSON（含 client_email 與 private_key）
# 用於建立 Drive 資料夾、設定資料夾權限
GOOGLE_SERVICE_ACCOUNT_JSON={}

# 使用者 OAuth（授權 Calendar、讀取 Google Docs 逐字稿）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# AI — 會議摘要（OpenAI）
# ─────────────────────────────────────────────
OPENAI_API_KEY=
# 摘要模型，預設 gpt-4.1-mini
OPENAI_MODEL=gpt-4.1-mini

# ─────────────────────────────────────────────
# AI — RAG 智慧查詢（Google Gemini）
# ─────────────────────────────────────────────
GEMINI_API_KEY=
# RAG 對話模型，預設 gemini-2.0-flash
CHAT_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────
# 管理用端點
# ─────────────────────────────────────────────
# 保護管理用端點（如 drive-scan cron）的密鑰
ADMIN_SECRET=

# ─────────────────────────────────────────────
# Tactiq 逐字稿自動掃描（選用）
# ─────────────────────────────────────────────
# TACTIQ_DRIVE_FOLDER_NAME=
# TACTIQ_TRANSCRIPT_FILE_NAME=
# TACTIQ_EXCLUDED_FILE_NAMES=
# TACTIQ_HOST_LINE_USER_ID=
# TACTIQ_DEFAULT_MEETING_DURATION_MINUTES=
